{
  "id": "optional",
  "title": {
    "en": "Optional capabilities",
    "zh": "可选能力"
  },
  "description": {
    "en": "These entries are useful extensions that are recognized by the pack, but are not part of the default distribution.",
    "zh": "这些条目是整合包认可的有用扩展，但不作为默认分发内容加入。"
  },
  "sections": [
    {
      "id": "online-play-enhancements",
      "title": {
        "en": "Online play enhancements",
        "zh": "联机体验增强"
      },
      "description": {
        "en": "These entries mainly improve the client-side experience when playing online or on compatible servers.",
        "zh": "这些条目主要改善玩家联机或加入兼容服务器时的客户端体验。"
      },
      "rows": [
        {
          "id": "proximity-voice-chat",
          "feature": {
            "en": "Proximity voice chat",
            "zh": "近距离语音聊天"
          },
          "versions": {
            "1.21.1": {
              "selected": "simple-voice-chat"
            }
          }
        },
        {
          "id": "server-resource-pack-unpacking",
          "feature": {
            "en": "Server resource-pack unpacking",
            "zh": "服务器资源包解包"
          },
          "versions": {
            "1.21.1": {
              "selected": "server-unpacker"
            }
          }
        },
        {
          "id": "multiplayer-client-enhancements",
          "feature": {
            "en": "Multiplayer client enhancements",
            "zh": "多人服务器客户端增强"
          },
          "versions": {
            "1.21.1": {
              "selected": "noxesium"
            }
          }
        },
        {
          "id": "remote-view-distance-cache",
          "feature": {
            "en": "Remote view-distance cache",
